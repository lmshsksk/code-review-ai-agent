# ================================
# AI 代码审查工具 - 环境变量配置
# ================================
# 使用说明:
# 1. 复制此文件并重命名为 .env
# 2. 填写必需的配置项
# 3. .env 文件不要提交到 Git (已在 .gitignore 中)

# ========================================
# 必需配置 (Required)
# ========================================

# GitLab 访问令牌 (需要 api, read_repository 权限)
# 获取方式: GitLab → Settings → Access Tokens
GITLAB_TOKEN=XXXXXXXXXXXXXXXXXXXXX

# GitLab API 地址
# 示例: https://gitlab.com/api/v4 或 https://your-gitlab-domain.com/api/v4
CI_API_V4_URL=http://gitlab.XXXXXXXXXXXXXXXXXXXXX

# 阿里云百炼平台 API 密钥
# 获取方式: https://dashscope.aliyuncs.com/
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXX

# ========================================
# 可选配置 (Optional)
# ========================================

# AI 模型配置
# 阿里云百炼平台 API 基础地址
OPENAI_BASE_URL=https://API/XXXXXXXXXXXXXXXXXXXXX

# 使用的 AI 模型
# 可选值: qwen3-coder-plus, qwen-plus, qwen-turbo 等
REVIEW_MODEL=qwen3-max

# 接入端口
WEBHOOK_PORT=80

# ----------------------------------------
# 审查参数
# ----------------------------------------

# 并发审查文件数 (建议: 3-5)
MAX_PARALLEL=3

# 单文件最大问题数限制
ISSUE_LIMIT=10

# 审查结果发布模式
# - report: Markdown 汇总报告 (默认)
# - inline: 精准行级评论
REVIEW_MODE=report

# ----------------------------------------
# 功能开关
# ----------------------------------------

# 是否启用 AST 分析 (建议启用以获得更准确的上下文)
ENABLE_AST=true

# 测试模式 (true: 只分析不发布评论, false: 正常发布)
DRY_RUN=false

# ----------------------------------------
# Diff 限制 (防止超大文件消耗过多 Token)
# ----------------------------------------

# Diff 最大行数限制
MAX_DIFF_LINES=500

# Diff 最大字符数限制
MAX_DIFF_CHARS=50000

# ----------------------------------------
# AST 分析配置
# ----------------------------------------

# 代码片段最大字符数
AST_MAX_SNIPPET_LENGTH=10000

# 代码块最大行数
AST_MAX_BLOCK_SIZE_LINES=150

# AST 遍历最大深度 (防止递归过深)
AST_MAX_DEPTH=60

# AST 解析超时时间 (毫秒)
AST_TIMEOUT_MS=8000

# ----------------------------------------
# 路径配置
# ----------------------------------------

# 项目根目录 (本地调试时使用，CI 环境会自动设置)
# PROJECT_ROOT=.

# 编码规范文件路径 (相对于项目根目录)
GUIDELINES_FILE=coding_guidelines.yaml

# ========================================
# 本地调试专用配置
# ========================================
# 注意: 以下变量仅用于本地调试 (debug_local.js)
# 在 GitLab CI 环境中会自动注入，无需手动配置

# 项目 ID (仅本地调试时需要，在 debug_local.js 中设置)
CI_PROJECT_ID=12345

# Merge Request IID (仅本地调试时需要，在 debug_local.js 中设置)
CI_MERGE_REQUEST_IID=67


